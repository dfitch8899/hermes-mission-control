# Copy to .env.local and fill in. Never commit real values.

# NextAuth (https://next-auth.js.org/configuration/options)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional: Cognito OAuth (all three required when enabled — see lib/auth.ts)
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=

# Hermes shared auth key — must match HERMES_SECRET_KEY in the hermes-agent task def.
# Used for inbound webhook validation (Hermes → MC) AND outbound dashboard calls (MC → Hermes).
HERMES_SECRET_KEY=

# Direct transport — bypasses Slack relay for model/kanban calls.
# Requires port forwarding: run scripts/hermes-forward.sh in a separate terminal.
# Set to "slack" to fall back to Slack relay (default when no tunnel is running).
HERMES_TRANSPORT=slack
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# AWS (credentials via env/instance role; region defaults in code)
AWS_REGION=us-east-2

# DynamoDB table names (defaults in lib/dynamodb.ts)
DYNAMODB_TABLE_TASKS=
DYNAMODB_TABLE_MEMORIES=
DYNAMODB_TABLE_CALENDAR=

# ECS
ECS_CLUSTER=
ECS_SERVICE=

# CloudWatch Logs
CLOUDWATCH_LOG_GROUP=

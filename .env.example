# Copy to .env.local and fill in. Never commit real values.

# NextAuth (https://next-auth.js.org/configuration/options)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Optional: Cognito OAuth (all three required when enabled — see lib/auth.ts)
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=

# Hermes agent webhook HMAC
HERMES_SECRET_KEY=

# AWS (credentials via env/instance role; region defaults in code)
AWS_REGION=us-east-2

# DynamoDB table names (defaults in lib/dynamodb.ts)
DYNAMODB_TABLE_TASKS=
DYNAMODB_TABLE_MEMORIES=
DYNAMODB_TABLE_CALENDAR=

# ECS
ECS_CLUSTER=
ECS_SERVICE=

# CloudWatch Logs
CLOUDWATCH_LOG_GROUP=
